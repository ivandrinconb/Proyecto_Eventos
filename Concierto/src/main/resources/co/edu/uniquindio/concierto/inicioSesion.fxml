<VBox alignment="CENTER" prefHeight="615.0" prefWidth="630.0" spacing="20.0" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="co.edu.uniquindio.concierto.viewController.InicioSesionViewController">
    <padding>
        <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
    </padding>
   <children>
      <AnchorPane prefHeight="575.0" prefWidth="585.0">
         <children>
            <Text layoutX="149.0" layoutY="128.0" strokeType="OUTSIDE" strokeWidth="0.0" text="Centro de Eventos ">
               <font>
                  <Font name="Times New Roman Bold" size="36.0" />
               </font>
            </Text>
            <Text layoutX="112.0" layoutY="259.0" strokeType="OUTSIDE" strokeWidth="0.0" text="Email:">
               <font>
                  <Font name="Times New Roman" size="18.0" />
               </font>
            </Text>
            <Text layoutX="112.0" layoutY="351.0" strokeType="OUTSIDE" strokeWidth="0.0" text="Password:">
               <font>
                  <Font name="Times New Roman" size="18.0" />
               </font>
            </Text>
            <TextField fx:id="TxtCorreo" layoutX="222.0" layoutY="239.0" prefHeight="26.0" prefWidth="206.0" />
            <TextField fx:id="TxtPassword" layoutX="222.0" layoutY="331.0" prefHeight="26.0" prefWidth="206.0" />
